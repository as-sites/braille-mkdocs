# Caddyfile — static file server for the MkDocs build output
# Railway injects $PORT at runtime; {$PORT:8080} falls back to 8080 locally.
:{$PORT:8080}

root * /srv
file_server

# Clean URLs: serve foo.html when /foo is requested (matches MkDocs output)
try_files {path} {path}/index.html {path}/ {path}.html

# Custom 404 page generated by MkDocs
handle_errors {
    rewrite * /404.html
    file_server
}
