# Neon Postgres connection string
DATABASE_URL=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# better-auth session signing secret
BETTER_AUTH_SECRET=

# Public URL of the Hono API — used by better-auth for cookie/redirect URL generation
# and by the Astro search modal / admin SPA
BETTER_AUTH_URL=
PUBLIC_API_URL=

# Origin of the admin SPA (e.g. http://localhost:5173 in dev, https://admin.example.com in prod)
# Used for CORS and better-auth trustedOrigins
ADMIN_ORIGIN=

# Shared secret for Astro <-> Hono internal cache invalidation
INTERNAL_SECRET=

# Initial admin user created on first startup (seed script)
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
